{
  "name": "yuri-rewrite",
  "version": "0.4.7",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "dev:browser": "vite --host 127.0.0.1 --mode browser",
    "build": "tsc && vite build",
    "test": "vitest run",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "verify": "powershell -ExecutionPolicy Bypass -File scripts/verify.ps1",
    "package:portable": "powershell -ExecutionPolicy Bypass -File scripts/package-portable.ps1",
    "package:portable:fresh": "powershell -ExecutionPolicy Bypass -File scripts/package-portable-fresh.ps1",
    "release:check": "powershell -ExecutionPolicy Bypass -File scripts/release-check.ps1"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-dialog": "^2.0.0",
    "diff": "^8.0.4",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-window": "^2.2.7",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^6.0.3",
    "jsdom": "^24.1.3",
    "typescript": "^5.6.3",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  }
}
