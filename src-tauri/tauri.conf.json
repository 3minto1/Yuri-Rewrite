{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Yuri Rewrite",
  "version": "0.1.4",
  "identifier": "com.local.yurirewrite",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Yuri Rewrite",
        "width": 1280,
        "height": 820,
        "minWidth": 1040,
        "minHeight": 700
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": []
  }
}
